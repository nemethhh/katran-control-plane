# Lightweight backend image for E2E tests.
#
# Sets up IPIP tunnel decapsulation and runs a simple HTTP server that
# identifies itself so tests can verify which backend handled the request.
FROM ubuntu:25.04

RUN apt-get update && apt-get install -y \
    iproute2 \
    kmod \
    python3 \
    iputils-ping \
    tcpdump \
    net-tools \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY tests/e2e/scripts/backend-entrypoint.sh /app/scripts/backend-entrypoint.sh
COPY tests/e2e/scripts/backend-server.py /app/scripts/backend-server.py

CMD ["/bin/bash"]
